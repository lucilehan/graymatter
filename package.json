{
  "name": "graymatter",
  "displayName": "GrayMatter Memory",
  "description": "Visualize and manage your AI agent's memory traces as an interactive 3D brain",
  "version": "0.1.3",
  "publisher": "lucilehan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucilehan/graymatter.git"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "claude",
    "ai",
    "memory",
    "brain",
    "visualization",
    "anthropic"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeBrain.open",
        "title": "Open GrayMatter",
        "category": "GrayMatter",
        "icon": "$(pulse)"
      },
      {
        "command": "claudeBrain.inspectMemory",
        "title": "Inspect Memory",
        "category": "GrayMatter"
      },
      {
        "command": "claudeBrain.addMemory",
        "title": "Add Memory",
        "category": "GrayMatter"
      },
      {
        "command": "claudeBrain.clearAll",
        "title": "Clear All Memories",
        "category": "GrayMatter"
      },
      {
        "command": "claudeBrain.exportMemories",
        "title": "Export Memories",
        "category": "GrayMatter"
      },
      {
        "command": "claudeBrain.importMemories",
        "title": "Import Memories",
        "category": "GrayMatter"
      },
      {
        "command": "claudeBrain.copyContext",
        "title": "Copy Relevant Context",
        "category": "GrayMatter"
      },
      {
        "command": "claudeBrain.distill",
        "title": "Distill Memories",
        "category": "GrayMatter"
      },
      {
        "command": "claudeBrain.checkContradictions",
        "title": "Check for Contradictions",
        "category": "GrayMatter"
      },
      {
        "command": "claudeBrain.menu",
        "title": "GrayMatter Actions",
        "category": "GrayMatter",
        "icon": "$(gear)"
      },
      {
        "command": "claudeBrain.showRelevantMemories",
        "title": "Show Relevant Memories",
        "category": "GrayMatter"
      },
      {
        "command": "claudeBrain.exportTeamBrain",
        "title": "Export Team Brain",
        "category": "GrayMatter",
        "icon": "$(organization)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-brain",
          "title": "GrayMatter",
          "icon": "media/brain-icon.svg"
        }
      ]
    },
    "views": {
      "claude-brain": [
        {
          "type": "webview",
          "id": "claudeBrain.brainView",
          "name": "Brain"
        },
        {
          "id": "claudeBrain.memoryList",
          "name": "Memory List"
        }
      ]
    },
    "configuration": {
      "title": "GrayMatter",
      "properties": {
        "claudeBrain.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your Anthropic API key for Claude interactions",
          "order": 0
        },
        "claudeBrain.model": {
          "type": "string",
          "default": "claude-sonnet-4-20250514",
          "enum": [
            "claude-sonnet-4-20250514",
            "claude-opus-4-6",
            "claude-haiku-4-5-20251001"
          ],
          "description": "Claude model to use for memory categorization",
          "order": 1
        },
        "claudeBrain.storagePath": {
          "type": "string",
          "default": "",
          "description": "Custom path for persistent memory storage (defaults to workspace .claude-brain/)",
          "order": 2
        },
        "claudeBrain.autoSummarize": {
          "type": "boolean",
          "default": true,
          "description": "Automatically summarize and categorize new memories using Claude",
          "order": 3
        },
        "claudeBrain.fastModel": {
          "type": "string",
          "default": "claude-haiku-4-5-20251001",
          "description": "Fast model used for contradiction detection (Haiku recommended)",
          "order": 4
        },
        "claudeBrain.strongModel": {
          "type": "string",
          "default": "claude-opus-4-6",
          "description": "Strong model used for contradiction resolution (Opus recommended)",
          "order": 5
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "claudeBrain.menu",
          "when": "view == claudeBrain.memoryList",
          "group": "navigation"
        },
        {
          "command": "claudeBrain.addMemory",
          "when": "view == claudeBrain.memoryList",
          "group": "1_actions@1"
        },
        {
          "command": "claudeBrain.copyContext",
          "when": "view == claudeBrain.memoryList",
          "group": "1_actions@2"
        },
        {
          "command": "claudeBrain.distill",
          "when": "view == claudeBrain.memoryList",
          "group": "1_actions@3"
        },
        {
          "command": "claudeBrain.importMemories",
          "when": "view == claudeBrain.memoryList",
          "group": "2_io@1"
        },
        {
          "command": "claudeBrain.exportMemories",
          "when": "view == claudeBrain.memoryList",
          "group": "2_io@2"
        },
        {
          "command": "claudeBrain.clearAll",
          "when": "view == claudeBrain.memoryList",
          "group": "3_danger@1"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeBrain.open",
          "when": "view == claudeBrain.memoryList"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
